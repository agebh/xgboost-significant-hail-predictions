def plot_roc_pr(y_true, y_prob, title_prefix="", outpath_prefix=None):
    """Creates and optionally saves ROC + PR plots."""
    # ROC
    fpr, tpr, _ = roc_curve(y_true, y_prob)
    aucroc = roc_auc_score(y_true, y_prob)

    plt.figure(figsize=(5.5, 4.2))
    plt.plot(fpr, tpr, label=f"AUCROC={aucroc:.4f}")
    plt.plot([0, 1], [0, 1], linestyle="--", linewidth=1, label="Random")
    plt.xlabel("False Positive Rate")
    plt.ylabel("True Positive Rate")
    plt.title(f"{title_prefix} ROC")
    plt.legend()
    plt.tight_layout()
    if outpath_prefix is not None:
        plt.savefig(outpath_prefix + "_roc.png", dpi=200)
    plt.show()

    # PR
    prec, rec, _ = precision_recall_curve(y_true, y_prob)
    aucpr = average_precision_score(y_true, y_prob)  # same spirit as AUC(PR); robust for rare events
    prevalence = float(np.mean(y_true))

    plt.figure(figsize=(5.5, 4.2))
    plt.plot(rec, prec, label=f"AUCPR={aucpr:.4f}")
    plt.axhline(prevalence, linestyle="--", linewidth=1, label=f"Baseline={prevalence:.4f}")
    plt.xlabel("Recall")
    plt.ylabel("Precision")
    plt.title(f"{title_prefix} Precision–Recall")
    plt.legend()
    plt.tight_layout()
    if outpath_prefix is not None:
        plt.savefig(outpath_prefix + "_pr.png", dpi=200)
    plt.show()

    return float(aucroc), float(aucpr)

