def gain_lift_by_decile(y_true, y_prob, n_bins=10):
    """
    Returns a DataFrame with deciles computed by sorting y_prob desc.
    decile 1 = top 10% highest probs.

    Columns:
      decile, n, positives, cum_n, cum_pos, cum_gain, lift
    """
    y_true = np.asarray(y_true).astype(int)
    y_prob = np.asarray(y_prob).astype(float)

    order = np.argsort(-y_prob)
    y_sorted = y_true[order]

    N = len(y_sorted)
    P = int(y_sorted.sum())
    if P == 0:
        # avoid divide-by-zero; still return structure
        bins = np.array_split(np.arange(N), n_bins)
        rows = []
        cum_n = 0
        for i, b in enumerate(bins, 1):
            n = len(b)
            cum_n += n
            rows.append({
                "decile": i, "n": n, "positives": 0,
                "cum_n": cum_n, "cum_pos": 0,
                "cum_gain": 0.0, "lift": np.nan
            })
        return pd.DataFrame(rows)

    bins = np.array_split(np.arange(N), n_bins)

    rows = []
    cum_n = 0
    cum_pos = 0

    for i, b in enumerate(bins, 1):
        n = len(b)
        pos = int(y_sorted[b].sum())
        cum_n += n
        cum_pos += pos

        frac_samples = cum_n / N
        cum_gain = cum_pos / P
        # lift at decile i = (cum_gain / frac_samples)
        lift = cum_gain / max(1e-12, frac_samples)

        rows.append({
            "decile": i,
            "n": n,
            "positives": pos,
            "cum_n": cum_n,
            "cum_pos": cum_pos,
            "cum_gain": float(cum_gain),
            "lift": float(lift),
        })

    return pd.DataFrame(rows)

