def confusion_metrics(y_true, y_prob, thr=0.5):
    """Confusion-matrix metrics at a fixed threshold."""
    y_pred = (y_prob >= thr).astype(np.int8)
    tn, fp, fn, tp = confusion_matrix(y_true, y_pred, labels=[0, 1]).ravel()

    acc  = (tp + tn) / max(1, (tp + tn + fp + fn))
    prec = tp / max(1, (tp + fp))
    sens = tp / max(1, (tp + fn))          # recall / TPR
    spec = tn / max(1, (tn + fp))          # TNR
    f1   = (2 * prec * sens) / max(1e-12, (prec + sens))

    return {
        "thr": float(thr),
        "tp": int(tp), "fp": int(fp), "tn": int(tn), "fn": int(fn),
        "accuracy": float(acc),
        "precision": float(prec),
        "sensitivity": float(sens),
        "specificity": float(spec),
        "f1": float(f1),
    }

# -------------------------------------------------------------------------
def confusion_matrix_normalized(y_true, y_prob, thr=0.5, normalize="true"):
    """
    normalize='true' -> row-normalized (each true class sums to 1)
    normalize='pred' -> column-normalized (each predicted class sums to 1)
    normalize='all'  -> normalized by total
    """
    y_pred = (y_prob >= thr).astype(np.int8)
    return confusion_matrix(y_true, y_pred, labels=[0, 1], normalize=normalize)

