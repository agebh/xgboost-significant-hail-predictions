def merge_years(dbkey: str, start_year: int, end_year: int, variable: str | None = None):
    """
    Merge all yearly NetCDF files for DB[dbkey] between start_year and end_year (inclusive)
    and return the hail DataArray (by default DB[dbkey]["hail_var"]).
    """
    cfg = DB[dbkey] # cfg = configuration
    years = [y for y in range(start_year, end_year + 1) if y in cfg["years"]]
    if not years:
        raise ValueError(f"No valid years in range for {dbkey}. Allowed: {cfg['years'].start}–{cfg['years'].stop - 1}")

    # building the file paths
    files = [os.path.join(cfg["dir"], cfg["pattern"].format(year=y)) for y in years]
    files = [f for f in files if Path(f).exists()]
    if not files:
        raise FileNotFoundError(f"No files found for {dbkey} in {start_year}–{end_year}")

    ds = xr.open_mfdataset(files, combine="by_coords")

    hail_var = cfg["hail_var"]
    size_var = next((n for n in cfg.get("size_vars", []) if n in ds.data_vars), None)
    
    return ds[[hail_var, size_var]]

    
