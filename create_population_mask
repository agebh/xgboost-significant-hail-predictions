# ---------- Subsetting helper ----------
def subset_bbox(da: xr.DataArray, bbox, lon_name="longitude", lat_name="latitude") -> xr.DataArray:
    """
    Subset to bbox = (min_lon, max_lon, min_lat, max_lat).
    Handles both ascending or descending latitude coordinates.
    """
    min_lon, max_lon, min_lat, max_lat = map(float, bbox)

    # subset longitude (assumes bbox doesn't cross the dateline)
    out = da.sel({lon_name: slice(min_lon, max_lon)})

    # subset latitude with correct orientation
    lat_vals = out[lat_name].values
    if lat_vals.size == 0:
        raise ValueError("Longitude slice returned empty result; check bbox or lon convention.")
    if lat_vals[0] <= lat_vals[-1]:  # ascending
        out = out.sel({lat_name: slice(min_lat, max_lat)})
    else:                            # descending
        out = out.sel({lat_name: slice(max_lat, min_lat)})

    return out

